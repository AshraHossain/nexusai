# NexusAI Environment Configuration
# Copy to .env and fill in your values

# ── App ──────────────────────────────────────────────────────────────────
APP_NAME=NexusAI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── LLM Provider ─────────────────────────────────────────────────────────
# Options: openai | ollama
LLM_PROVIDER=openai

# OpenAI-compatible (OpenAI, Azure, Groq, vLLM, Together, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=4096

# Ollama (local, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.1

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexusai:nexusai@localhost:5432/nexusai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Platform Integrations ─────────────────────────────────────────────────
SENTINELAI_URL=http://localhost:8001
SENTINELAI_API_KEY=

EVALOPS_URL=http://localhost:8002
EVALOPS_API_KEY=

KNOWLEDGEOPS_URL=http://localhost:8003
KNOWLEDGEOPS_API_KEY=

# ── Security ──────────────────────────────────────────────────────────────
NEXUSAI_API_KEY=your-internal-api-key-here
SENTINEL_RISK_THRESHOLD=50

# ── Orchestrator ──────────────────────────────────────────────────────────
MAX_AGENT_RETRIES=3
WORKFLOW_TIMEOUT_SECONDS=300
HUMAN_APPROVAL_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_WORKFLOWS=50

# ── Observability ─────────────────────────────────────────────────────────
OTEL_ENABLED=true
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=nexusai

# ── Evaluation ────────────────────────────────────────────────────────────
EVALOPS_MIN_QUALITY=0.70
EVALOPS_MIN_GROUNDEDNESS=0.75
